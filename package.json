    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "license": "MIT",
  "author": "zzzhizhi",
  "repository": {
    "type": "git",
    "url": "https://github.com/zzzhizhia/ingest.git"
  },
  "homepage": "https://github.com/zzzhizhia/ingest",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  }
